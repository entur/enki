    "lint-staged": "16.4.0",
    "lit-html": "3.3.2",
    "msw": "2.12.14",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "sass": "1.98.0",
    "source-map-explorer": "2.5.3",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vite-plugin-svgr": "5.0.0",
    "vitest": "4.1.2",
    "vitest-sonar-reporter": "3.0.0"
