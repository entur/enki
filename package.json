    "date-fns": "4.1.0",
    "duration-fns": "3.0.2",
    "file-saver": "2.0.5",
    "flag-icons": "7.5.0",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "leaflet": "1.9.4",
    "lit": "3.3.2",
    "lodash.clonedeep": "4.5.0",
    "lodash.isempty": "4.4.0",
    "lodash.isequal": "4.5.0",
    "oidc-client-ts": "3.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-helmet-async": "2.0.5",
    "react-intl": "10.1.1",
    "react-leaflet": "5.0.0",
    "react-oidc-context": "3.3.1",
    "react-redux": "9.2.0",
    "react-router-dom": "7.13.2",
