{
  "name": "@entur/enki",
  "version": "0.672.0",
  "author": "Entur",
  "private": false,
  "repository": "https://github.com/entur/enki.git",
  "scripts": {
    "test": "vitest",
    "start": "vite",
    "build": "tsc && vite build",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "analyze": "source-map-explorer 'build/assets/*.js'",
    "server": "vite preview",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "4.1.6",
    "@azure/msal-browser": "4.30.0",
    "@azure/msal-react": "3.0.29",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@entur/react-component-toggle": "1.1.0",
    "@fintraffic/fds-coreui-css": "0.1.3",
    "@internationalized/date": "3.12.0",
    "@lit-labs/react": "2.1.3",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-date-pickers": "8.27.2",
    "@reduxjs/toolkit": "2.11.2",
    "@turf/boolean-clockwise": "7.3.4",
    "@turf/helpers": "7.3.4",
    "@turf/kinks": "7.3.4",
    "axios": "1.15.0",
